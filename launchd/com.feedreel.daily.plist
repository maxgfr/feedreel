<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent for feedreel: runs scripts/run-daily.sh every day at 07:00.

  IMPORTANT: replace both occurrences of the __PROJECT_DIR__ placeholder with the
  ABSOLUTE path of the project root (e.g. /Users/you/feedreel), then install:

      # 1. Replace the placeholder (example with sed):
      sed "s#__PROJECT_DIR__#$PWD#g" launchd/com.feedreel.daily.plist \
        > ~/Library/LaunchAgents/com.feedreel.daily.plist

      # 2. Load the agent:
      launchctl load ~/Library/LaunchAgents/com.feedreel.daily.plist

      # To unload:  launchctl unload ~/Library/LaunchAgents/com.feedreel.daily.plist

  The run-daily.sh script resolves FEEDREEL_LOG_FILE itself (logs/veille-<date>.log);
  StandardOutPath/StandardErrorPath below additionally capture the job's raw output.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.feedreel.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/scripts/run-daily.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/logs/launchd.err.log</string>
</dict>
</plist>
