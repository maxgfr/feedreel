# ════════════════════════════════════════════════════════════════════════════
#  Social publishing secrets — COPY this file to `.env` (gitignored).
#  NEVER add real tokens to the repository. See docs/publish-setup.md.
#
#  MULTILINGUAL variant: a `_<LANG>` suffix (UPPERCASE) takes priority
#  over the base variable. E.g. with a category in `en`, YT_REFRESH_TOKEN_EN
#  wins over YT_REFRESH_TOKEN. Define only the base if you publish everything
#  to a single account.
# ════════════════════════════════════════════════════════════════════════════

# ─── YouTube Data API v3 (OAuth "Desktop app") ──────────────────────────────
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# Multilingual (optional): YT_REFRESH_TOKEN_EN=...  YT_CLIENT_ID_EN=...

# ─── TikTok Content Posting API ─────────────────────────────────────────────
# The TikTok access token expires in ~24 h. For hands-off
# automation, provide the refresh credentials below instead: the
# pipeline exchanges a fresh token on each run and persists it (cache/).
TIKTOK_ACCESS_TOKEN=
# Automatic refresh (recommended for the daily job):
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
# Multilingual (optional): TIKTOK_REFRESH_TOKEN_EN=...

# ─── Instagram Graph API (Business/Creator account + Facebook Page) ─────────
IG_USER_ID=
IG_ACCESS_TOKEN=
# Automatic refresh of the long-lived token (~60 d): provide the Meta app below
# and the pipeline re-exchanges the token before expiry (otherwise manual renewal).
FB_APP_ID=
FB_APP_SECRET=
# Multilingual (optional): IG_USER_ID_EN=...  IG_ACCESS_TOKEN_EN=...

# ─── Cloudflare R2 (temporary public HTTPS hosting, required by Instagram) ───
# R2 is S3-compatible. PUBLIC_BASE_URL = public domain of the bucket (no trailing /).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# AWS S3 variant (if hosting.provider = s3):
# S3_REGION=  S3_ACCESS_KEY_ID=  S3_SECRET_ACCESS_KEY=  S3_BUCKET=  S3_PUBLIC_BASE_URL=
